# Sandy SMS Agent — Environment Variables
# Copy to .env and fill in values

# GHL Private Integration Token (DD Installs sub-account)
GHL_PIT_TOKEN=
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_LOCATION_ID=

# Anthropic API key for Sandy's AI message generation
ANTHROPIC_API_KEY=

# Supabase (sms_messages table for logging)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# VAPI (voice AI — call.ended webhooks trigger follow-ups)
VAPI_API_KEY=

# DD API Gateway base URL
DD_API_URL=https://datadriverapi.com

# Server
PORT=3000
